{
  "name": "@ordine/create",
  "version": "0.0.2-preview.4",
  "private": false,
  "description": "Create a local Ordine instance — npm create @ordine",
  "repository": {
    "type": "git",
    "url": "https://github.com/forge-town/ordine",
    "directory": "apps/create"
  },
  "bin": {
    "create-ordine": "dist/index.js"
  },
  "files": [
    "dist",
    "app",
    "migrations"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:cli": "bun build ./src/index.ts --target=node --format=esm --outfile=./dist/index.js --external=embedded-postgres --external=postgres",
    "build:app": "rm -rf app && cp -r ../app/.output app",
    "build": "bun run build:cli && bun run build:app",
    "dev": "bun src/index.ts",
    "check-types": "tsc --noEmit",
    "lint": "oxlint --config ./.oxlintrc.json src/",
    "quality": "bun run check-types && bun run lint && bun run test",
    "test": "vitest run",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "embedded-postgres": "^18.1.0-beta.16",
    "neverthrow": "^8.2.0",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ordine/app": "workspace:*",
    "@repo/oxlint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.6.0",
    "typescript": "5.9.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20"
  }
}
