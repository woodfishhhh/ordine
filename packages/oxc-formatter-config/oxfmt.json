{
  "$schema": "https://oxc.rs/schema/formatter.json",
  "indentStyle": "space",
  "indentSize": 2,
  "lineEnding": "lf",
  "printWidth": 100,
  "quoteStyle": "single",
  "trailingComma": "all",
  "semicolons": true,
  "arrowParens": "always",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "jsxSingleQuote": false
}
